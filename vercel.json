{
    "version": 2,
    "cleanUrls": true,
    "public": true,
    "rewrites": [
        {
            "source": "/",
            "destination": "/frontend-adire/index.html"
        },
        {
            "source": "/js/(.*)",
            "destination": "/frontend-adire/js/$1"
        },
        {
            "source": "/css/(.*)",
            "destination": "/frontend-adire/css/$1"
        },
        {
            "source": "/images/(.*)",
            "destination": "/frontend-adire/images/$1"
        },
        {
            "source": "/img/(.*)",
            "destination": "/frontend-adire/img/$1"
        },
        {
            "source": "/pages/(.*)",
            "destination": "/frontend-adire/pages/$1"
        }
    ]
}